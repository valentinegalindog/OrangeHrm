<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Inter Rapidísimo Test Suite" verbose="1">

    <test name="Test Agregar empleado" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <parameter name="headless" value="false"/>

        <classes>
            <class name="com.orangehrm.tests.AddEmployee">
                <methods>
                    <include name="testAddEmployee"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- Para ejecución en CI -->
    <test name="CI Tests" parallel="false">
        <parameter name="browser" value="chrome"/>
        <parameter name="headless" value="true"/>

        <classes>
            <class name="com.orangehrm.tests.AddEmployee">
                <methods>
                    <include name="testAddEmployee"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>